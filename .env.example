# Required (preferred): separate keys for spot and futures testnet
BINANCE_SPOT_TESTNET_API_KEY=your_spot_testnet_api_key
BINANCE_SPOT_TESTNET_API_SECRET=your_spot_testnet_api_secret
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret

# If Binance gives you an Ed25519 private key instead of an HMAC secret,
# keep it on a single line with literal "\n" escapes instead of pasting
# a multi-line PEM block directly into .env.
# Example:
# BINANCE_SPOT_TESTNET_API_SECRET=-----BEGIN PRIVATE KEY-----\nBASE64...\n-----END PRIVATE KEY-----

# Optional fallback: shared testnet key pair
# BINANCE_TESTNET_API_KEY=
# BINANCE_TESTNET_API_SECRET=

# Trading target
SYMBOL=SOLUSDT

# Capital and risk profile
TOTAL_CAPITAL_USDT=500
SPOT_CAPITAL_RATIO=0.40
RISK_PER_TRADE_PCT=0.005
STOP_LOSS_PCT=0.012
TAKE_PROFIT_PCT=0.024
DAILY_LOSS_LIMIT_PCT=0.03
FUTURES_MAX_LEVERAGE=50

# Optional: if Binance returns -1021 timestamp errors, try a negative offset.
# Example: -1500 (milliseconds)
BINANCE_TIMESTAMP_OFFSET_MS=0

# Optional: user WS keepalive interval in seconds.
# Lower values (e.g. 20-60) can reduce frequent reconnects on unstable networks.
BINANCE_USER_WS_KEEPALIVE_SECS=1800

# Optional: proxy for Binance HTTP/WS (example for Clash/V2Ray local proxy).
# BINANCE_PROXY_URL=http://127.0.0.1:7890
